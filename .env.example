# Public app configuration. This endpoint is safe to bundle; it must point to
# your HTTPS backend and must never contain an OpenAI API key.
EXPO_PUBLIC_AI_CHAT_ENDPOINT=https://api.example.com

# Server-only configuration for `npm run ai:server`.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
ALLOWED_ORIGINS=http://localhost:8084,https://your-production-domain.example
PORT=8787
# Keep the local default. Set HOST=0.0.0.0 only inside a protected production host/container.
HOST=127.0.0.1
